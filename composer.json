{
    "name": "sources/forum",
    "description": "Sources.RU Forum",
    "require": {
        "openid/php-openid": "dev-master",
        "filp/whoops": "1.1.*@stable",
        "serafim/asset": "0.*",
        "monolog/monolog": "1.10.0",
        "leafo/scssphp": "0.0.12"
    },
    "autoload": {
        "classmap": [
            "app/classes",
            "app/models",
            "app/helpers"
        ],
        "psr-4": {
            "Views\\": [
                "app/views"
            ]
        }
    },
    "require-dev": {
        "phpunit/phpunit": "^4.1",
        "phpunit/dbunit": ">=1.2"
    },
    "config": {
        "audit": {
            "block-insecure": false
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
